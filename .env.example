# Supabase — copie para .env.local e preencha com as chaves do seu projeto
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Modo do app. Deixe vazio no projeto do cardápio.
# No SEGUNDO projeto Vercel (o do painel), defina como: painel
# Assim a raiz desse endereço abre direto o /admin.
VITE_APP_MODE=
